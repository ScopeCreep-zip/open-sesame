# Open Sesame development environment
# Operationalized by .envrc (direnv) and .mise.toml
# Copy to .env for local overrides, or use as-is via .envrc

# Mold linker via clang (requires mold + clang from nix devShell)
CARGO_TARGET_X86_64_UNKNOWN_LINUX_GNU_LINKER=clang
CARGO_TARGET_X86_64_UNKNOWN_LINUX_GNU_RUSTFLAGS="-C link-arg=-fuse-ld=mold -Z threads=8"
CARGO_TARGET_AARCH64_UNKNOWN_LINUX_GNU_LINKER=clang
CARGO_TARGET_AARCH64_UNKNOWN_LINUX_GNU_RUSTFLAGS="-C link-arg=-fuse-ld=mold -Z threads=8"

# Prevent rustup from downloading/installing when nix provides the toolchain.
# Must match the channel in rust-toolchain.toml.
RUSTUP_TOOLCHAIN=nightly-2026-04-15

# Backtrace for development
RUST_BACKTRACE=1
